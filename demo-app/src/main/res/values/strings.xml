    <!-- Scenarios -->
    <string name="scenario_tls_tls_title">TLS Config API → TLS Host</string>
    <string name="scenario_tls_tls_desc">Fetches pin config from TLS Config API (:8091), then connects to a TLS host (:8443). No client certificate enrollment needed.</string>
    <string name="scenario_tls_mtls_title">TLS Config API → mTLS Host</string>
    <string name="scenario_tls_mtls_desc">Fetches pin config from TLS Config API (:8091), then connects to an mTLS host (:8444). Client certificate required for the target host.</string>
    <string name="scenario_mtls_tls_title">mTLS Config API → TLS Host</string>
    <string name="scenario_mtls_tls_desc">Fetches pin config from mTLS Config API (:8092) using client cert, then connects to a TLS host (:8443).</string>
    <string name="scenario_mtls_mtls_title">mTLS Config API → mTLS Host</string>
    <string name="scenario_mtls_mtls_desc">Fetches pin config from mTLS Config API (:8092) using client cert, then connects to an mTLS host (:8444). Client certificate required for both.</string>

