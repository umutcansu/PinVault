<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) icin veri cikarma kurallari.
  PinVault client sertifikalari hem bulut yedeklemeden hem de
  cihazdan cihaza transferden haric tutulur.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="pinvault_client_cert.xml" />
        <!-- M-07: pin config downgrade'ini engelle -->
        <exclude domain="sharedpref" path="ssl_cert_config.xml" />
        <exclude domain="sharedpref" path="ssl_cert_config_default-tls.xml" />
        <exclude domain="sharedpref" path="ssl_cert_config_secure-mtls.xml" />
        <exclude domain="sharedpref" path="pinvault_vault_files.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="pinvault_client_cert.xml" />
        <exclude domain="sharedpref" path="ssl_cert_config.xml" />
        <exclude domain="sharedpref" path="ssl_cert_config_default-tls.xml" />
        <exclude domain="sharedpref" path="ssl_cert_config_secure-mtls.xml" />
        <exclude domain="sharedpref" path="pinvault_vault_files.xml" />
    </device-transfer>
</data-extraction-rules>
